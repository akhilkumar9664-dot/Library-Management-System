# ── Maven build output ────────────────────────────────────────────────────────
target/
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ── IDE — IntelliJ IDEA ───────────────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr

# ── IDE — VS Code ─────────────────────────────────────────────────────────────
.vscode/
.classpath
.project
.settings/
.factorypath

# ── IDE — Eclipse ─────────────────────────────────────────────────────────────
*.launch
.apt_generated
.springBeans
.sts4-cache

# ── OS generated files ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.tmp
*.log

# ── Secrets — NEVER commit these ─────────────────────────────────────────────
# application-prod.properties  ← add if you create one
*.env

# ── Spring Boot devtools restart file ─────────────────────────────────────────
.reloadtrigger
